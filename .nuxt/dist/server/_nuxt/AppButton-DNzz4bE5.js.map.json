{"file":"AppButton-DNzz4bE5.js","mappings":";;;AAiBA,MAAM,OACJ;;;;;;;;;;;;;AARF,UAAM,QAAQ;AAUd,UAAM,WAAW;AAAA,MACf,OACE;AAAA,MACF,SACE;AAAA,MACF,OAAO;AAAA,IAAA;AAGT,UAAM,QAAQ;AAAA,MACZ,IAAI;AAAA,MACJ,IAAI;AAAA,MACJ,IAAI;AAAA,IAAA;AAGN,UAAM,UAAU,SAAS,MAAM,CAAC,MAAM,SAAS,MAAM,OAAO,GAAG,MAAM,MAAM,IAAI,CAAC,CAAC;AAEjF,UAAM,MAAM,SAAS,MAAM;AACzB,UAAI,MAAM,GAAI,QAAO;AACrB,UAAI,MAAM,KAAM,QAAO;AACvB,aAAO;AAAA,IACT,CAAC;AAED,UAAM,WAAW,SAAS,MAAM;AAC9B,UAAI,MAAM,GAAI,QAAO,EAAE,IAAI,MAAM,GAAA;AACjC,UAAI,MAAM;AACR,eAAO;AAAA,UACL,MAAM,MAAM;AAAA,UACZ,GAAI,MAAM,WAAW,EAAE,QAAQ,UAAU,KAAK,0BAA0B,CAAA;AAAA,QAAC;AAE7E,aAAO,EAAE,MAAM,MAAM,KAAA;AAAA,IACvB,CAAC;;AAIiBA,qBAAA,OAAAC,YAAAC,wBAAAC,MAAA,GAAA,CAAG,GAAAC,WAAUD,MAAA,QAAA,GAAQ,EAAG,OAAOA,MAAA,OAAA,EAAA,GAAO,MAAA,GAAA;AAAA,yBAAtD,CAQY,GAAAE,QAAAC,UAAA,aAAA;;;;;;cAPVC,WAAQ,KAAA,QAAA,SAAA;AAAA,cACRN,YAKO,QAAA;AAAA,gBAJL,OAAM;AAAA,gBACN,eAAY;AAAA,cAAA,GACb,KAED;AAAA,YAAA;AAAA;;;;;;;;;;;;;","names":["_ssrRenderVNode","_createVNode","_resolveDynamicComponent","_unref","_mergeProps","_push","_parent","_renderSlot"],"sources":["../../../../components/AppButton.vue"],"sourcesContent":["<script setup lang=\"ts\">\ninterface Props {\n  to?: string\n  href?: string\n  variant?: 'solid' | 'outline' | 'ghost'\n  size?: 'sm' | 'md' | 'lg'\n  external?: boolean\n  type?: 'button' | 'submit' | 'reset'\n}\n\nconst props = withDefaults(defineProps<Props>(), {\n  variant: 'solid',\n  size: 'md',\n  external: false,\n  type: 'button',\n})\n\nconst base =\n  'inline-flex items-center justify-center gap-2 font-sans font-medium tracking-wide transition-all duration-400 ease-expo rounded-full whitespace-nowrap select-none will-change-transform group'\n\nconst variants = {\n  solid:\n    'bg-brown text-cream hover:bg-wine dark:bg-cream dark:text-brown dark:hover:bg-wine dark:hover:text-cream',\n  outline:\n    'border border-current text-current hover:bg-brown hover:text-cream dark:hover:bg-cream dark:hover:text-brown',\n  ghost: 'text-current hover:opacity-70',\n}\n\nconst sizes = {\n  sm: 'px-5 py-2 text-xs uppercase tracking-eyebrow',\n  md: 'px-7 py-3.5 text-sm uppercase tracking-eyebrow',\n  lg: 'px-9 py-4 text-sm uppercase tracking-eyebrow',\n}\n\nconst classes = computed(() => [base, variants[props.variant], sizes[props.size]])\n\nconst tag = computed(() => {\n  if (props.to) return resolveComponent('NuxtLink')\n  if (props.href) return 'a'\n  return 'button'\n})\n\nconst bindings = computed(() => {\n  if (props.to) return { to: props.to }\n  if (props.href)\n    return {\n      href: props.href,\n      ...(props.external ? { target: '_blank', rel: 'noopener noreferrer' } : {}),\n    }\n  return { type: props.type }\n})\n</script>\n\n<template>\n  <component :is=\"tag\" v-bind=\"bindings\" :class=\"classes\">\n    <slot />\n    <span\n      class=\"inline-block transition-transform duration-500 ease-expo group-hover:translate-x-1\"\n      aria-hidden=\"true\"\n    >\n      →\n    </span>\n  </component>\n</template>\n"],"version":3}