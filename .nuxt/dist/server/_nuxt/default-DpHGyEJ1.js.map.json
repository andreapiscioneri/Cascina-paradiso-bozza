UAAA,CAAA,CAAA,EAAA;AAAA;;8CAAFA,KAAAA,GAAE,UAAA,CAAA,GAAA,CAAA;AAAA,YAAA;AAAA;;;;;QAEI,IAAIH,MAAA,UAAA,EAAU,SAAA;AAAA,QAAa,OAAM;AAAA,MAAA;yBAA5C,CAEW,GAAAC,QAAAC,UAAA,aAAA;;qCADNC,KAAAA,GAAE,YAAA,CAAA,CAAA,EAAA;AAAA;;8CAAFA,KAAAA,GAAE,YAAA,CAAA,GAAA,CAAA;AAAA,YAAA;AAAA;;;;;QAEI,IAAIH,MAAA,UAAA,EAAU,OAAA;AAAA,QAAW,OAAM;AAAA,MAAA;yBAA1C,CAEW,GAAAC,QAAAC,UAAA,aAAA;;qCADNC,KAAAA,GAAE,UAAA,CAAA,CAAA,EAAA;AAAA;;8CAAFA,KAAAA,GAAE,UAAA,CAAA,GAAA,CAAA;AAAA,YAAA;AAAA;;;;;QAEI,IAAIH,MAAA,UAAA,EAAU,WAAA;AAAA,QAAe,OAAM;AAAA,MAAA;yBAA9C,CAEW,GAAAC,QAAAC,UAAA,aAAA;;qCADNC,KAAAA,GAAE,cAAA,CAAA,CAAA,EAAA;AAAA;;8CAAFA,KAAAA,GAAE,cAAA,CAAA,GAAA,CAAA;AAAA,YAAA;AAAA;;;;oVAcFA,KAAAA,GAAE,gBAAA,CAAA,woDAkCEH,MAAA,IAAA,CAAI,uCAA0BG,KAAAA,GAAE,eAAA,CAAA;WAExBH,MAAA,kBAAA,GAAkB;;UAAG,IAAIA,MAAA,UAAA,EAAU,UAAA;AAAA,UAAc,OAAM;AAAA,QAAA;2BAAxE,CAAwI,GAAAC,QAAAC,UAAA,aAAA;;;;;gCAAzB,gBAAc;AAAA,cAAA;AAAA;;;;;;;WAC5GF,MAAA,kBAAA,GAAkB;;UAAG,IAAIA,MAAA,UAAA,EAAU,mBAAA;AAAA,UAAuB,OAAM;AAAA,QAAA;2BAAjF,CAAmJ,GAAAC,QAAAC,UAAA,aAAA;;;;;gCAA3B,kBAAgB;AAAA,cAAA;AAAA;;;;;;;WACvHF,MAAA,kBAAA,GAAkB;;UAAG,IAAIA,MAAA,UAAA,EAAU,SAAA;AAAA,UAAa,OAAM;AAAA,QAAA;2BAAvE,CAAsI,GAAAC,QAAAC,UAAA,aAAA;;;;;gCAAxB,eAAa;AAAA,cAAA;AAAA;;;;;;;;;;;;;;;;;;;;;;;;;ACtF5H,YAAA,OAAAU,eAAAC,WAAA,EAAA,OAAM,wBAAoB,MAAA,CAAA,CAAA,GAAA;;;;;;;;;;;;;;;;;","names":["_unref","_push","_parent","$t","_createBlock","_createVNode","_ssrRenderList","_ssrInterpolate","_createTextVNode","_toDisplayString","_ssrRenderComponent","_ssrRenderAttr","_ssrRenderAttrs","_mergeProps"],"sources":["../../../../node_modules/@nuxtjs/color-mode/dist/runtime/composables.js","../../../../components/ThemeToggle.vue","../../../../components/LangToggle.vue","../../../../components/SiteNavbar.vue","../../../../components/SiteFooter.vue","../../../../layouts/default.vue"],"sourcesContent":["import { useState } from \"#imports\";\nexport const useColorMode = () => {\n  return useState(\"color-mode\").value;\n};\n","<script setup lang=\"ts\">\nconst colorMode = useColorMode()\n\nconst cycle = () => {\n  const order = ['light', 'dark', 'system']\n  const current = colorMode.preference\n  const next = order[(order.indexOf(current) + 1) % order.length]\n  colorMode.preference = next\n}\n\nconst icon = computed(() => {\n  if (colorMode.preference === 'system') return 'system'\n  return colorMode.value === 'dark' ? 'dark' : 'light'\n})\n\nconst label = computed(() => {\n  if (colorMode.preference === 'system') return 'Auto'\n  return colorMode.preference === 'dark' ? 'Dark' : 'Light'\n})\n</script>\n\n<template>\n  <button\n    type=\"button\"\n    class=\"w-10 h-10 rounded-full border border-[color:var(--line)] inline-flex items-center justify-center leading-none transition-colors duration-400 ease-expo hover:bg-brown hover:text-cream dark:hover:bg-cream dark:hover:text-brown\"\n    :aria-label=\"`Theme: ${label}`\"\n    :title=\"`Theme: ${label}`\"\n    @click=\"cycle\"\n  >\n    <!-- Sun -->\n    <svg\n      v-if=\"icon === 'light'\"\n      width=\"16\"\n      height=\"16\"\n      viewBox=\"0 0 24 24\"\n      fill=\"none\"\n      stroke=\"currentColor\"\n      stroke-width=\"1.5\"\n      stroke-linecap=\"round\"\n      class=\"block\"\n      aria-hidden=\"true\"\n    >\n      <circle cx=\"12\" cy=\"12\" r=\"4\" />\n      <path\n        d=\"M12 3v2M12 19v2M3 12h2M19 12h2M5.64 5.64l1.41 1.41M16.95 16.95l1.41 1.41M5.64 18.36l1.41-1.41M16.95 7.05l1.41-1.41\"\n      />\n    </svg>\n    <!-- Moon -->\n    <svg\n      v-else-if=\"icon === 'dark'\"\n      width=\"16\"\n      height=\"16\"\n      viewBox=\"0 0 24 24\"\n      fill=\"none\"\n      stroke=\"currentColor\"\n      stroke-width=\"1.5\"\n      stroke-linecap=\"round\"\n      class=\"block\"\n      aria-hidden=\"true\"\n    >\n      <path d=\"M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z\" />\n    </svg>\n    <!-- System -->\n    <svg\n      v-else\n      width=\"16\"\n      height=\"16\"\n      viewBox=\"0 0 24 24\"\n      fill=\"none\"\n      stroke=\"currentColor\"\n      stroke-width=\"1.5\"\n      stroke-linecap=\"round\"\n      class=\"block\"\n      aria-hidden=\"true\"\n    >\n      <rect x=\"3\" y=\"4\" width=\"18\" height=\"14\" rx=\"2\" />\n      <path d=\"M8 21h8M12 18v3\" />\n    </svg>\n  </button>\n</template>\n","<script setup lang=\"ts\">\nconst { locale, setLocale } = useI18n()\n\nconst switchLang = () => {\n  const next = locale.value === 'it' ? 'en' : 'it'\n  setLocale(next as any)\n}\n</script>\n\n<template>\n  <button\n    type=\"button\"\n    class=\"w-10 h-10 rounded-full border border-[color:var(--line)] inline-flex items-center justify-center transition-colors duration-400 ease-expo hover:bg-brown hover:text-cream dark:hover:bg-cream dark:hover:text-brown\"\n    :aria-label=\"`Language: ${locale}`\"\n    :title=\"`Language: ${locale === 'it' ? 'Italiano' : 'English'}`\"\n    @click=\"switchLang\"\n  >\n    <svg\n      v-if=\"locale === 'it'\"\n      viewBox=\"0 0 3 2\"\n      class=\"h-3.5 w-5 rounded-[2px] shadow-[0_0_0_1px_rgba(255,255,255,0.25)]\"\n      aria-hidden=\"true\"\n    >\n      <rect width=\"3\" height=\"2\" fill=\"#012169\" />\n      <path d=\"M0 0l3 2M3 0L0 2\" stroke=\"#FFFFFF\" stroke-width=\"0.4\" />\n      <path d=\"M0 0l3 2M3 0L0 2\" stroke=\"#C8102E\" stroke-width=\"0.18\" />\n      <rect x=\"1.2\" y=\"0\" width=\"0.6\" height=\"2\" fill=\"#FFFFFF\" />\n      <rect x=\"0\" y=\"0.7\" width=\"3\" height=\"0.6\" fill=\"#FFFFFF\" />\n      <rect x=\"1.32\" y=\"0\" width=\"0.36\" height=\"2\" fill=\"#C8102E\" />\n      <rect x=\"0\" y=\"0.82\" width=\"3\" height=\"0.36\" fill=\"#C8102E\" />\n    </svg>\n\n    <svg\n      v-else\n      viewBox=\"0 0 3 2\"\n      class=\"h-3.5 w-5 rounded-[2px] shadow-[0_0_0_1px_rgba(255,255,255,0.25)]\"\n      aria-hidden=\"true\"\n    >\n      <rect width=\"1\" height=\"2\" x=\"0\" fill=\"#009246\" />\n      <rect width=\"1\" height=\"2\" x=\"1\" fill=\"#FFFFFF\" />\n      <rect width=\"1\" height=\"2\" x=\"2\" fill=\"#CE2B37\" />\n    </svg>\n  </button>\n</template>\n","<script setup lang=\"ts\">\n/**\n * Navbar — fixed, transparent at top, condensed on scroll.\n * Desktop: horizontal links. Mobile: hamburger → full-screen overlay.\n */\nconst { t } = useI18n()\nconst localePath = useLocalePath()\n\nconst isScrolled = ref(false)\nconst isOpen = ref(false)\n\nconst onScroll = () => {\n  isScrolled.value = window.scrollY > 24\n}\n\nonMounted(() => {\n  window.addEventListener('scroll', onScroll, { passive: true })\n  onScroll()\n})\nonBeforeUnmount(() => window.removeEventListener('scroll', onScroll))\n\nwatch(isOpen, (v) => {\n  if (typeof document === 'undefined') return\n  document.body.style.overflow = v ? 'hidden' : ''\n})\n\nconst route = useRoute()\nconst isOnPosizionamento = computed(() => route.path.includes('/posizionamento'))\n\nwatch(isOnPosizionamento, (value) => {\n  if (value) isOpen.value = false\n})\n\nconst links = computed(() => {\n  const base = [\n    { to: localePath('/storia'), label: t('nav.storia') },\n    { to: localePath('/menu'), label: t('nav.menu') },\n    { to: localePath('/contatti'), label: t('nav.contatti') },\n  ]\n  return base\n})\n</script>\n\n<template>\n  <header\n    class=\"fixed top-0 left-0 right-0 z-[50] transition-all duration-500 ease-expo\"\n    :class=\"[\n      isScrolled || isOpen\n        ? 'backdrop-blur-xl bg-cream/80 dark:bg-noir/80 border-b border-[color:var(--line)]'\n        : 'bg-transparent',\n    ]\"\n  >\n    <div class=\"container-x flex items-center justify-between h-[var(--nav-h)]\">\n      <!-- Logo -->\n      <NuxtLink\n        v-if=\"!isOnPosizionamento\"\n        :to=\"localePath('/')\"\n        class=\"flex items-center gap-3 group\"\n        @click=\"isOpen = false\"\n      >\n        <svg\n          width=\"32\"\n          height=\"32\"\n          viewBox=\"0 0 72 72\"\n          fill=\"none\"\n          class=\"transition-transform duration-600 ease-expo group-hover:rotate-[8deg]\"\n          aria-hidden=\"true\"\n        >\n          <circle cx=\"36\" cy=\"36\" r=\"34\" stroke=\"currentColor\" stroke-width=\"1.5\" />\n          <path\n            d=\"M22 44c4-10 10-14 14-14s10 4 14 14\"\n            stroke=\"currentColor\"\n            stroke-width=\"1.5\"\n            stroke-linecap=\"round\"\n          />\n          <circle cx=\"36\" cy=\"28\" r=\"2.5\" fill=\"currentColor\" />\n        </svg>\n        <span class=\"flex flex-col leading-none\">\n          <span class=\"font-serif text-fluid-lg\">Cascina Paradiso</span>\n          <span class=\"eyebrow opacity-60 hidden sm:inline\">{{ $t('brand.since') }}</span>\n        </span>\n      </NuxtLink>\n\n      <div v-else class=\"flex items-center gap-3\">\n        <svg\n          width=\"32\"\n          height=\"32\"\n          viewBox=\"0 0 72 72\"\n          fill=\"none\"\n          aria-hidden=\"true\"\n        >\n          <circle cx=\"36\" cy=\"36\" r=\"34\" stroke=\"currentColor\" stroke-width=\"1.5\" />\n          <path\n            d=\"M22 44c4-10 10-14 14-14s10 4 14 14\"\n            stroke=\"currentColor\"\n            stroke-width=\"1.5\"\n            stroke-linecap=\"round\"\n          />\n          <circle cx=\"36\" cy=\"28\" r=\"2.5\" fill=\"currentColor\" />\n        </svg>\n        <span class=\"flex flex-col leading-none\">\n          <span class=\"font-serif text-fluid-lg\">Cascina Paradiso</span>\n          <span class=\"eyebrow opacity-60 hidden sm:inline\">{{ $t('brand.since') }}</span>\n        </span>\n      </div>\n\n      <!-- Desktop nav -->\n      <nav v-if=\"!isOnPosizionamento\" class=\"hidden lg:flex items-center gap-10\">\n        <NuxtLink\n          v-for=\"link in links\"\n          :key=\"link.to\"\n          :to=\"link.to\"\n          class=\"text-fluid-sm line-hover\"\n          active-class=\"opacity-100\"\n        >\n          {{ link.label }}\n        </NuxtLink>\n      </nav>\n\n      <!-- Right cluster -->\n      <div class=\"flex items-center gap-4\">\n        <ThemeToggle class=\"hidden sm:flex\" />\n        <LangToggle class=\"hidden sm:flex\" />\n        <AppButton\n          v-if=\"!isOnPosizionamento\"\n          :to=\"localePath('/prenotazioni')\"\n          variant=\"solid\"\n          size=\"sm\"\n          class=\"hidden md:inline-flex\"\n        >\n          {{ $t('nav.prenota') }}\n        </AppButton>\n\n        <!-- Hamburger -->\n        <button\n          v-if=\"!isOnPosizionamento\"\n          type=\"button\"\n          class=\"lg:hidden w-10 h-10 flex flex-col items-center justify-center gap-1.5\"\n          :aria-expanded=\"isOpen\"\n          aria-label=\"Menu\"\n          @click=\"isOpen = !isOpen\"\n        >\n          <span\n            class=\"block w-6 h-px bg-current transition-transform duration-400 ease-expo\"\n            :class=\"isOpen ? 'translate-y-[6px] rotate-45' : ''\"\n          />\n          <span\n            class=\"block w-6 h-px bg-current transition-opacity duration-200\"\n            :class=\"isOpen ? 'opacity-0' : ''\"\n          />\n          <span\n            class=\"block w-6 h-px bg-current transition-transform duration-400 ease-expo\"\n            :class=\"isOpen ? '-translate-y-[6px] -rotate-45' : ''\"\n          />\n        </button>\n      </div>\n    </div>\n\n    <!-- Mobile overlay -->\n    <Transition\n      enter-active-class=\"transition-all duration-500 ease-expo\"\n      leave-active-class=\"transition-all duration-400 ease-expo\"\n      enter-from-class=\"opacity-0\"\n      leave-to-class=\"opacity-0\"\n    >\n      <div\n        v-if=\"isOpen && !isOnPosizionamento\"\n        class=\"fixed inset-0 top-[var(--nav-h)] z-[40] bg-cream dark:bg-noir grain lg:hidden\"\n      >\n        <div class=\"container-x py-12 flex flex-col h-full\">\n          <nav class=\"flex flex-col gap-6\">\n            <NuxtLink\n              v-for=\"(link, i) in links\"\n              :key=\"link.to\"\n              :to=\"link.to\"\n              class=\"font-serif text-fluid-4xl\"\n              :style=\"{ transitionDelay: `${i * 60 + 100}ms` }\"\n              @click=\"isOpen = false\"\n            >\n              {{ link.label }}\n            </NuxtLink>\n          </nav>\n          <div class=\"mt-auto py-8 flex flex-col gap-4\">\n            <div class=\"flex gap-4\">\n              <ThemeToggle />\n              <LangToggle />\n            </div>\n            <AppButton v-if=\"!isOnPosizionamento\" :to=\"localePath('/prenotazioni')\" variant=\"solid\" @click=\"isOpen = false\">\n              {{ $t('nav.prenota') }}\n            </AppButton>\n          </div>\n        </div>\n      </div>\n    </Transition>\n  </header>\n</template>\n","<script setup lang=\"ts\">\nconst localePath = useLocalePath()\nconst year = new Date().getFullYear()\nconst route = useRoute()\nconst isOnPosizionamento = computed(() => route.path.includes('/posizionamento'))\n</script>\n\n<template>\n  <footer class=\"bg-noir text-cream grain mt-32\">\n    <!-- Oversized wordmark -->\n    <div class=\"container-x pt-24 pb-10 border-b border-white/10\">\n      <p class=\"eyebrow opacity-50 mb-6\">{{ $t('footer.built') }}</p>\n      <h2\n        class=\"font-serif font-light text-fluid-6xl md:text-fluid-7xl leading-tightest tracking-tightest whitespace-nowrap\"\n      >\n        Cascina <span class=\"italic\">Paradiso.</span>\n      </h2>\n    </div>\n\n    <div class=\"container-x grid md:grid-cols-[1fr_auto_auto] gap-12 py-14\">\n      <!-- Tagline + address -->\n      <div class=\"max-w-md\">\n        <p class=\"font-serif text-fluid-xl mb-4 whitespace-pre-line\">{{ $t('footer.tagline') }}</p>\n        <p class=\"text-fluid-sm opacity-70\">{{ $t('footer.address') }}</p>\n      </div>\n\n      <!-- Navigation -->\n      <div class=\"flex flex-col gap-3\">\n        <span class=\"eyebrow opacity-50\">Nav</span>\n        <NuxtLink :to=\"localePath('/')\" class=\"line-hover text-fluid-sm\">\n          {{ $t('nav.home') }}\n        </NuxtLink>\n        <NuxtLink :to=\"localePath('/storia')\" class=\"line-hover text-fluid-sm\">\n         