{"file":"menu-xSyGFQ6j.js","mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;QAWI,eAAA;AAAA,QACA,OAAM;AAAA,MAAA,iJAIC,QAAA,IAAI,wFAE0D,QAAA,IAAI,0KAKpE,QAAA,KAAK;;;;;;;;;;;;;;ACtBd,UAAA,EAAA,GAAA,IAAA,GAAA,IAAA,QAAA;AAEA,YAAA;AAAA,MAAA,OAAA,MAAA,GAAA,EAAA,iBAAA,CAAA,MAAA,EAAA,YAAA,CAAA;AAAA,MAAA,MAAA;AAAA,QAAA,EAAA,MAAA,eAAA,SAAA,MAAA,EAAA,YAAA,EAAA;AAAA,MAAA;AAAA,IAAA,CAAA;AAWA,UAAA,aAAA;AAAA,MAAmB;AAAA,QACjB,KAAA;AAAA,QACO,OAAA;AAAA,MAEH;AAAA,MACJ;AAAA,QACA,KAAA;AAAA,QACO,OAAA;AAAA,MAEH;AAAA,MACJ;AAAA,QACA,KAAA;AAAA,QACO,OAAA;AAAA,MAEH;AAAA,MACJ;AAAA,QACA,KAAA;AAAA,QACO,OAAA;AAAA,MAEH;AAAA,MACJ;AAAA,QACA,KAAA;AAAA,QACO,OAAA;AAAA,MAEH;AAAA,IACJ;AAGF,UAAA,WAAA,CAAA,QAAA;AACE,YAAA,QAAA,GAAA,cAAA,GAAA,EAAA;AACA,aAAA,MAAA,QAAA,KAAA,IAAA,MAAA,IAAA,CAAA,UAAA;AAAA,QAAiD,MAAA,GAAA,KAAA,IAAA;AAAA,QAC7B,MAAA,GAAA,KAAA,IAAA;AAAA,QACA,OAAA,GAAA,KAAA,KAAA;AAAA,MACE,EAAA,IAAA,CAAA;AAAA,IACf;;;;;;;;;;UAgDa,KAAA,KAAA,GAAA,mBAAA,IAAA,GAAA,EAAA;AAAA,UACyB,OAAA,IAAA,MAAA,IAAA,aAAA;AAAA,UAC1B,SAAA;AAAA,QACT,GAAA,MAAA,OAAA,CAAA;;;;UAOG,OAAA;AAAA,QACG,GAAA;AAAA;;;YAE0B,OAAA;;;cAAA;AAAA;;;;;AAKRA,sBAAA,SAAA,IAAA,GAAA,GAAA,CAAA,MAAA,QAAA;;;YACC,MAAA,KAAA;AAAA,YACX,MAAA,KAAA;AAAA,YACA,OAAA,KAAA;AAAA,UACC,GAAA,MAAA,OAAA,CAAA;AAAA;;;;IAWwC;AAAA;;;;;;;;","names":["_ssrRenderList"],"sources":["../../../../components/MenuItem.vue","../../../../pages/menu.vue"],"sourcesContent":["<script setup lang=\"ts\">\ninterface Props {\n  name: string\n  desc: string\n  price: string\n}\ndefineProps<Props>()\n</script>\n\n<template>\n  <article\n    data-reveal\n    class=\"group flex items-start justify-between gap-6 py-6 border-b border-[color:var(--line)] last:border-0\"\n  >\n    <div class=\"flex-1\">\n      <h4 class=\"font-serif text-fluid-xl mb-1 transition-colors duration-400 group-hover:text-wine\">\n        {{ name }}\n      </h4>\n      <p class=\"text-fluid-sm opacity-70 max-w-prose leading-relaxed\">{{ desc }}</p>\n    </div>\n    <span\n      class=\"font-serif text-fluid-xl shrink-0 tabular-nums after:content-['€'] after:text-fluid-base after:opacity-60 after:ml-0.5\"\n    >\n      {{ price }}\n    </span>\n  </article>\n</template>\n","<script setup lang=\"ts\">\nconst { t, tm, rt } = useI18n()\n\nuseSeoMeta({\n  title: () => `${t('menu.hero.title')} — ${t('brand.name')}`,\n  description: () => t('menu.intro'),\n})\n\ninterface MenuEntry {\n  name: string\n  desc: string\n  price: string\n}\n\nconst categories = [\n  {\n    key: 'antipasti',\n    image:\n      'https://images.unsplash.com/photo-1528735602780-2552fd46c7af?auto=format&fit=crop&w=1200&q=85',\n  },\n  {\n    key: 'primi',\n    image:\n      'https://images.unsplash.com/photo-1473093295043-cdd812d0e601?auto=format&fit=crop&w=1200&q=85',\n  },\n  {\n    key: 'brace',\n    image:\n      'https://images.unsplash.com/photo-1529692236671-f1f6cf9683ba?auto=format&fit=crop&w=1200&q=85',\n  },\n  {\n    key: 'contorni',\n    image:\n      'https://images.unsplash.com/photo-1518291344630-4857135fb581?auto=format&fit=crop&w=1200&q=85',\n  },\n  {\n    key: 'dolci',\n    image:\n      'https://images.unsplash.com/photo-1565958011703-44f9829ba187?auto=format&fit=crop&w=1200&q=85',\n  },\n]\n\nconst getItems = (key: string): MenuEntry[] => {\n  const items = tm(`menu.items.${key}`) as any[]\n  return Array.isArray(items) ? items.map(item => ({\n    name: rt(item.name),\n    desc: rt(item.desc),\n    price: rt(item.price),\n  })) : []\n}\n</script>\n\n<template>\n  <div>\n    <!-- HERO -->\n    <section class=\"relative h-[100svh] min-h-[640px] w-full overflow-hidden bg-noir text-cream\">\n      <div class=\"absolute inset-0\">\n        <img\n          src=\"https://images.unsplash.com/photo-1544025162-d76694265947?auto=format&fit=crop&w=2400&q=85\"\n          alt=\"Carne alla brace — Menu Cascina Paradiso\"\n          class=\"w-full h-full object-cover\"\n          fetchpriority=\"high\"\n        />\n        <div\n          class=\"absolute inset-0\"\n          style=\"background: linear-gradient(180deg, rgba(15,15,15,0.9) 0%, rgba(15,15,15,0.8) 40%, rgba(15,15,15,0.995) 100%);\"\n        />\n      </div>\n      <div class=\"relative z-10 h-full container-x flex flex-col justify-end pb-20 md:pb-28\">\n        <div class=\"eyebrow mb-6 text-cream/80\">\n          <span class=\"inline-block w-8 h-px bg-cream/60 mr-3 align-middle\" />\n          {{ $t('menu.hero.eyebrow') }}\n        </div>\n        <h1\n          class=\"font-serif font-light text-fluid-7xl leading-tightest tracking-tightest max-w-5xl text-balance text-cream\"\n        >\n          {{ $t('menu.hero.title') }}\n        </h1>\n        <p class=\"mt-8 max-w-xl text-fluid-lg opacity-90 leading-relaxed\">\n          {{ $t('menu.hero.subtitle') }}\n        </p>\n      </div>\n    </section>\n\n    <!-- Category blocks -->\n    <div class=\"container-x space-y-section-lg pb-section-lg\">\n      <section\n        v-for=\"(cat, i) in categories\"\n        :key=\"cat.key\"\n        class=\"grid lg:grid-cols-[1fr_1.3fr] gap-10 md:gap-20 items-start\"\n      >\n        <div\n          class=\"lg:sticky lg:top-[calc(var(--nav-h)+3rem)]\"\n          :class=\"i % 2 === 1 ? 'lg:order-2' : ''\"\n        >\n          <ImageReveal\n            :src=\"cat.image\"\n            :alt=\"$t(`menu.categories.${cat.key}`)\"\n            :ratio=\"i % 2 === 0 ? 'portrait' : 'landscape'\"\n            rounded\n          />\n          <span class=\"eyebrow text-wine mt-6 block\">0{{ i + 1 }} — {{ $t(`menu.categories.${cat.key}`) }}</span>\n        </div>\n\n        <div :class=\"i % 2 === 1 ? 'lg:order-1' : ''\">\n          <AnimatedText\n            as=\"h2\"\n            class=\"font-serif text-fluid-5xl leading-tightest tracking-tightest mb-10\"\n          >\n            {{ $t(`menu.categories.${cat.key}`) }}\n          </AnimatedText>\n\n          <div>\n            <MenuItem\n              v-for=\"(item, idx) in getItems(cat.key)\"\n              :key=\"`${cat.key}-${idx}`\"\n              :name=\"item.name\"\n              :desc=\"item.desc\"\n              :price=\"item.price\"\n            />\n          </div>\n        </div>\n      </section>\n    </div>\n\n    <!-- Note -->\n    <section class=\"container-x pb-section\">\n      <div class=\"max-w-3xl mx-auto text-center border-t border-[color:var(--line)] pt-14\">\n        <p class=\"eyebrow text-wine mb-4\">* Nota</p>\n        <p class=\"text-fluid-base opacity-70 leading-relaxed\">{{ $t('menu.note') }}</p>\n      </div>\n    </section>\n  </div>\n</template>\n"],"version":3}